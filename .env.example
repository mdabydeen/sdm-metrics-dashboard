# JIRA Configuration
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=service-account@company.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_STORY_POINTS_FIELD=customfield_10016
JIRA_SPRINT_FIELD=customfield_10020

# GitHub Configuration
GITHUB_TOKEN=your-github-token-here
GITHUB_ORG=yourorg

# ServiceNow Configuration (Phase 2)
SNOW_INSTANCE=yourorg.service-now.com
SNOW_USER=service-account@company.com
SNOW_PASSWORD=

# Database Configuration
# Local: data/metrics.db (SQLite)
# Cloud Phase 3: postgresql://user:password@host:5432/sdm_metrics
DATABASE_URL=data/metrics.db

# Team Configuration
TEAMS_CONFIG=config/teams.yaml

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Capacity App
CAPACITY_APP_PORT=8000

# Logging
LOG_LEVEL=INFO
